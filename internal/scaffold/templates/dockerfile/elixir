# Elixir toolchain + the three agent CLIs. Tune versions to your project.
FROM elixir:1.18-otp-27
RUN apt-get update \
 && apt-get install -y --no-install-recommends curl git ca-certificates postgresql-client \
 && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
 && apt-get install -y --no-install-recommends nodejs \
 && npm install -g @anthropic-ai/claude-code @openai/codex @google/gemini-cli \
 && apt-get clean && rm -rf /var/lib/apt/lists/* \
 && git config --system --add safe.directory /workspace \
 && useradd -m -u 1000 -s /bin/bash node
USER node
RUN mix local.hex --force && mix local.rebar --force
WORKDIR /workspace
