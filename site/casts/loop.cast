[13.775, "o", "⚙ Bash \u001b[2mgo test ./internal/health/... -run TestLivenessCache\u001b[0m\r\n"]
[14.475, "o", "⚙ Bash \u001b[2mgit commit -q -m \"health: cache the liveness probe for 5s (singleflight)\"\u001b[0m\r\n"]
